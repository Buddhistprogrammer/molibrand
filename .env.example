# ============================================================
# 环境变量示例 — 复制为 .env 后填写真实值
#   cp .env.example .env
# ============================================================

# ---------- 阿里云百炼 DashScope ----------
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 模型配置（默认值来自 Architecture.md 第5章选型总表）
LLM_CHAT_MODEL=qwen3.7-plus
LLM_FLASH_MODEL=qwen3.6-flash
LLM_OMNI_MODEL=qwen3.5-omni-plus
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIM=1024
RERANK_MODEL=qwen3-rerank
ASR_MODEL=fun-asr-realtime
TTS_MODEL=cosyvoice-v3.5-plus

# ---------- MySQL（业务数据；生产用阿里云 RDS） ----------
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DB=brand_consult
MYSQL_USER=brand_app
MYSQL_PASSWORD=brand_app_pwd
MYSQL_ROOT_PASSWORD=root_pwd

# ---------- PostgreSQL + pgvector（向量数据） ----------
PG_HOST=postgres
PG_PORT=5432
PG_DB=brand_consult
PG_USER=brand_app
PG_PASSWORD=brand_app_pwd

# ---------- Redis（可选：会话缓存/限流） ----------
REDIS_URL=redis://redis:6379/0

# ---------- 阿里云 OSS + STS（文件上传直传） ----------
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_REGION=cn-hangzhou
OSS_BUCKET=your-bucket
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
STS_ROLE_ARN=acs:ram::123456789:role/oss-upload-role
STS_DURATION_SECONDS=900

# ---------- 应用配置 ----------
APP_ENV=development
JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:5173,http://localhost
# 每日 API 调用上限（成本护栏，见 Architecture 9.2）
DAILY_LLM_CALL_LIMIT=2000
